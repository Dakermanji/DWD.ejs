<!--! views/layouts/_navTheme.ejs -->
<%
	const themeItems = [
		{ key: 'light', icon: 'bi-sun', label: t('theme.light') },
		{ key: 'dark', icon: 'bi-moon-stars', label: t('theme.dark') },
		{ key: 'system', icon: 'bi-circle-half', label: t('theme.system') },
	];
%>

<% const themeTrigger = t('theme.trigger') %>
<li class="nav-item dropdown">
	<a
		class="nav-link"
		href="#"
		id="themeDropdown"
		role="button"
		data-bs-toggle="dropdown"
		aria-expanded="false"
		aria-label="<%= themeTrigger %>"
	>
		<span class='has-tooltip' data-bs-title="<%= themeTrigger %>">
			<span class="nav-icon">
				<i class="bi bi-circle-half" data-theme-trigger-icon aria-hidden="true"></i>
			</span>
			<span class="nav-text" data-theme-trigger-text></span>
		</span>
	</a>
	<ul
		class="dropdown-menu <%= currentLang === 'ar' ? 'dropdown-menu-start' : 'dropdown-menu-end' %>"
		aria-labelledby="themeDropdown"
	>
		<% themeItems.forEach((theme) => { %>
			<li>
				<button
					type="button"
					class="d-flex justify-content-between dropdown-item align-items-center"
					data-theme-value="<%= theme.key %>"
					aria-label="<%= theme.label %>"
				>
					<span class='nav-icon'>
						<i class="bi <%= theme.icon %>" aria-hidden="true"></i>
					</span>
					<span class="theme-label"><%= theme.label %></span>
				</button>
			</li>
		<% }) %>
	</ul>
</li>
