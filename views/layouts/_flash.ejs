<!--! views/layouts/_flash.ejs -->

<%
const types = ['error', 'success', 'info', 'warning'];

const bootstrapClassByType = {
	error: 'danger',
	success: 'success',
	info: 'info',
	warning: 'warning',
};

const groupedErrors = locals.errors || [];
%>

<% if (groupedErrors.length > 0) { %>
	<% groupedErrors.forEach((key) => { %>
		<div class="flash-message alert alert-danger fade show mb-0" role="alert">
			<%= t(key) %>
		</div>
	<% }) %>
<% } %>

<% types.forEach((type) => { %>
	<% const msgs = locals[type] || []; %>
	<% const bs = bootstrapClassByType[type]; %>

	<% msgs.forEach((key) => { %>
		<div class="flash-message alert alert-<%= bs %> fade show mb-0" role="alert">
			<%= t(key) %>
		</div>
	<% }) %>
<% }) %>
