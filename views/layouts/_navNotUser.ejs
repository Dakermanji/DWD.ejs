<!--! views/layouts/_navNotUser.ejs -->
<% const authTitle = `${t('auth:signin.title')} / ${t('auth:signup.title')}`; %>

<li class="nav-item">
	<a
		href="#"
		class="nav-link has-tooltip"
		data-bs-toggle="modal"
		data-bs-target="#authModal"
		aria-label="<%= authTitle %>"
		data-bs-title="<%= authTitle %>"
	>
		<span class='nav-icon'>
			<i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
		</span>
		<span class="nav-text"><%= authTitle %></span>
	</a>
</li>
