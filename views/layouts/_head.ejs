<!--! views/layouts/_head.ejs -->
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Mobile browsers -->
    <meta name="theme-color" content="#ff7f27" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111111" media="(prefers-color-scheme: dark)" />

    <meta name="description" content="Dakermanji Solutions builds secure web and backend systems for practical business needs." />
    <meta name="keywords" content="Dakermanji Solutions, secure web development, backend systems, API development, Montreal developer" />

    <!-- TODO: SEO -->
    <meta property="og:title" content="Dakermanji Solutions" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="" />
    <meta property="og:image" content="" />
    <meta property="og:description" content="Secure web and backend systems for practical business needs." />

    <title>
      <%= typeof titleKey !== 'undefined' ? `${t(titleKey)} 🔸 Dakermanji Solutions` : 'Dakermanji Solutions' %>
    </title>

    <!-- Favicons -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/light/favicon-32x32.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/dark/favicon-32x32.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicons/light/favicon-16x16.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicons/dark/favicon-16x16.png" media="(prefers-color-scheme: dark)" />
    <link rel="shortcut icon" href="/favicons/light/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/light/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Dakermanji" />
    <link rel="manifest" href="/favicons/light/site.webmanifest" media="(prefers-color-scheme: light)" />
    <link rel="manifest" href="/favicons/dark/site.webmanifest" media="(prefers-color-scheme: dark)" />

    <!-- Bootstrap -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
      defer
    ></script>

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
    />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />

    <!-- Static Styles -->
    <% const staticStyles = ['tokens','base', 'layout', 'ui-bar'] %>
    <% if (user) staticStyles.push('social') %>
    <% staticStyles.forEach((style) => { %>
    <link rel="stylesheet" href="/css/root/<%= style %>.css" />
    <% }) %>

    <!-- Static Scripts -->
    <% const staticScripts = ['theme', 'dropdownMenu', 'tooltips', 'modals', 'flash'] %>
    <% if (user) staticScripts.push('social') %>
    <% staticScripts.forEach((script) => { %>
    <script src="/js/root/<%= script %>.js" defer></script>
    <% }) %>

    <!-- Dynamic page styles -->
    <% styles.forEach((style) => { %>
    <link rel="stylesheet" href="/css/<%= style %>.css" />
    <% }) %>

    <!-- Dynamic page scripts -->
    <% scripts.forEach((script) => { %>
    <script src="/js/<%= script %>.js" defer></script>
    <% }) %>
</head>
