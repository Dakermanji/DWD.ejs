<!--! views/home/_services.ejs -->
<%
	const services = t('home:services', { returnObjects: true });
	const serviceItems = ['api', 'database', 'backend'].map((key) => services[key]);
%>

<section id="services" class="py-5">
	<div class="container">
		<div class="row justify-content-center text-center mb-4">
			<div class="col-12 col-lg-8">
				<h2 class="mb-3"><%= services.title %></h2>
			</div>
		</div>

		<div class="row g-4 justify-content-center">
			<% serviceItems.forEach((service) => { %>
				<div class="col-12 col-md-6 col-xl-4">
					<article class="card h-100 border-0 shadow-sm bg-body-tertiary text-center">
						<div class="card-body p-4 p-lg-5">
							<div class="mb-4">
								<i
									class="bi <%= service.icon %> fs-1"
									aria-hidden="true"
								></i>
							</div>

							<h3 class="h4 card-title mb-3">
								<%= service.title %>
							</h3>

							<p class="card-text mb-0">
								<%= service.description %>
							</p>
						</div>
					</article>
				</div>
			<% }) %>
		</div>
	</div>
</section>
