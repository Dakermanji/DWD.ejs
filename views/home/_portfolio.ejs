<!--! views/home/_portfolio.ejs -->
<% const portfolio = t('home:portfolio', { returnObjects: true }) %>

<section id="portfolio" class="py-5">
	<div class="container">
		<div class="portfolio-background">
			<div class="row g-4 align-items-stretch">
				<div class="col-12">
					<h2 class="mb-4 text-center"><%= portfolio.title %></h2>
				</div>
			</div>

			<div class="row g-4 align-items-stretch" id="portfolio-grid">
				<% Object.entries(portfolio.items || {}).forEach(([key, item]) => { %>
					<%
						if (!item) return;

						const images = Array.isArray(item.images) && item.images.length
							? item.images
							: ['main'];
					%>

					<div class="col-12 col-md-6 col-lg-4 col-xl-3 portfolio-item">
						<article
							class="card h-100 portfolio-card border-0"
							data-project="<%= key %>"
							data-images-count="<%= images.length %>"
						>
							<div
								class="portfolio-media position-relative overflow-hidden"
								data-slides="<%= images.length %>"
								data-interval="2200"
							>
								<% images.forEach((imageName, index) => { %>
									<img
										src="/images/home/portfolio/<%= key %>/<%= imageName %>_<%= currentLang %>.jpg"
										class="portfolio-image <%= index === 0 ? 'active' : '' %>"
										alt="<%= item.title %> - <%= imageName.replaceAll('_', ' ') %>"
										loading="lazy"
										<%= index === 0 ? '' : 'aria-hidden="true"' %>
									/>
								<% }) %>

								<% if (images.length > 1) { %>
									<div class="portfolio-dots" aria-hidden="true">
										<% images.forEach((_, index) => { %>
											<span
												class="portfolio-dot <%= index === 0 ? 'active' : '' %>"
												data-slide-index="<%= index %>"
											></span>
										<% }) %>
									</div>
								<% } %>
							</div>

							<div class="card-body d-flex flex-column">
								<h3 class="card-title h4 mb-3"><%= item.title %></h3>

								<p class="card-text mb-3"><%= item.description %></p>

								<% if (Array.isArray(item.tech) && item.tech.length) { %>
									<ul class="list-inline mb-4 portfolio-tech-list">
										<% item.tech.forEach((tech) => { %>
											<li class="list-inline-item portfolio-tech-badge"><%= tech %></li>
										<% }) %>
									</ul>
								<% } %>

								<div class="mt-auto mx-auto">
									<a
										href="/<%= item.link %>"
										class="btn btn-primary portfolio-btn px-4"
										aria-label="<%= `${portfolio.view} - ${item.title}` %>"
									>
										<%= portfolio.view %>
									</a>
								</div>
							</div>
						</article>
					</div>
				<% }) %>

				<div class="col-12 col-md-6 col-lg-4 col-xl-3 portfolio-item">
					<article class="card h-100 portfolio-card border-0 portfolio-card--placeholder">
						<div class="portfolio-media position-relative overflow-hidden">
							<img
								src="/images/home/portfolio/under_construction/<%= currentLang %>.png"
								class="portfolio-image active"
								alt="<%= portfolio.under_construction.alt %>"
								loading="lazy"
							/>
						</div>

						<div class="card-body d-flex flex-column justify-content-center text-center">
							<h3 class="card-title h4 mb-3">
								<%= portfolio.under_construction.title %>
							</h3>

							<p class="card-text text-muted mb-0">
								<%= portfolio.under_construction.soon %>
							</p>
						</div>
					</article>
				</div>
			</div>

			<div class="mt-4 text-center">
				<button
					type="button"
					id="portfolio-show-more"
					class="btn btn-outline-primary"
				>
					<%= portfolio.see_more_btn %>
				</button>
			</div>
		</div>
	</div>
</section>
