<!--! views/profile/_account.ejs -->
<section aria-labelledby="profile-account-title" class="py-4">
	<div class="d-flex align-items-center gap-3">
		<div class="position-relative flex-shrink-0">
			<div
				id="avatar"
				class="profile-avatar"
				style="background-color: <%= account.avatar.background %>;"
			>
				<img
					src="<%= account.avatar.src %>"
					alt=""
					class="avatar-img"
				/>
			</div>
			<button
				type="button"
				class="profile-avatar-edit has-tooltip"
				data-avatar-modal-trigger
				data-avatar-modal-url="/profile/avatar-modal"
				data-bs-title="<%= t('common:editAvatar') %>"
				aria-label="<%= t('common:editAvatar') %>"
			>
				<i class="bi bi-pencil-fill" aria-hidden="true"></i>
			</button>

			<% if (account.countryCode) { %>
				<span
					class="avatar-country has-tooltip"
					data-bs-title="<%= account.countryName %>"
				>
					<span
						class="fi fi-<%= account.countryCode.toLowerCase() %> avatar-country__flag"
						role="img"
						aria-label="<%= account.countryName %>"
					></span>
				</span>
			<% } %>
		</div>

		<div class="min-w-0 profile-account-details">
			<div class="profile-username" data-profile-username>
				<div class="profile-username__display" data-username-display>
					<h2 id="profile-account-title" class="h4 mb-1">
						<%= account.username %>
					</h2>
					<button
						type="button"
						class="profile-icon-button has-tooltip"
						data-username-edit
						data-bs-title="<%= t('common:editName') %>"
						aria-label="<%= t('common:editName') %>"
					>
						<i class="bi bi-pencil-fill" aria-hidden="true"></i>
					</button>
				</div>

				<form
					class="profile-username__form d-none"
					method="POST"
					action="/profile/username"
					data-username-form
				>
					<%- include('../partials/_csrf') %>
					<input
						type="text"
						class="form-control profile-username__input"
						name="username"
						value="<%= account.username %>"
						required
						dir="ltr"
					/>
					<button
						type="submit"
						class="profile-icon-button profile-icon-button--success has-tooltip"
						data-bs-title="<%= t('common:saveName') %>"
						aria-label="<%= t('common:saveName') %>"
					>
						<i class="bi bi-check-lg" aria-hidden="true"></i>
					</button>
					<button
						type="button"
						class="profile-icon-button profile-icon-button--danger has-tooltip"
						data-username-cancel
						data-bs-title="<%= t('common:cancel') %>"
						aria-label="<%= t('common:cancel') %>"
					>
						<i class="bi bi-x-lg" aria-hidden="true"></i>
					</button>
				</form>
			</div>
			<p class="mb-0 text-body-muted"><%= account.email %></p>
			<div class="profile-country mt-2" data-profile-country>
				<div class="profile-country__display" data-country-display>
					<span class="text-body-muted">
						<%= account.countryName || t('common:noCountry') %>
					</span>
					<button
						type="button"
						class="profile-icon-button has-tooltip"
						data-country-edit
						data-country-editor-url="/profile/country-editor"
						data-bs-title="<%= t('common:editCountry') %>"
						aria-label="<%= t('common:editCountry') %>"
					>
						<i class="bi bi-pencil-fill" aria-hidden="true"></i>
					</button>
				</div>
				<div data-country-editor></div>
			</div>
		</div>
	</div>
</section>
