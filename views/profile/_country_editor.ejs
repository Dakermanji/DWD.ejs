<!--! views/profile/_country_editor.ejs -->

<form
	class="profile-country__form"
	method="POST"
	action="/profile/country"
	data-country-form
>
	<%- include('../partials/_csrf') %>
	<input
		id="profileCountryCode"
		type="hidden"
		name="countryCode"
		value="<%= account.countryCode || '' %>"
	/>
	<div class="dropdown complete-signup-country profile-country-picker">
		<button
			id="profileCountryDropdown"
			type="button"
			class="form-select complete-signup-country__toggle text-start"
			data-bs-toggle="dropdown"
			data-bs-auto-close="true"
			aria-expanded="false"
		>
			<span class="complete-signup-country__selected">
				<% if (account.countryCode) { %>
					<span
						class="fi fi-<%= account.countryCode.toLowerCase() %> complete-signup-country__flag"
						aria-hidden="true"
					></span>
					<span><%= account.countryName %></span>
				<% } else { %>
					<span class="complete-signup-country__placeholder">
						<%= t('common:selectCountry') %>
					</span>
				<% } %>
			</span>
		</button>
		<ul
			class="dropdown-menu complete-signup-country__menu w-100"
			aria-labelledby="profileCountryDropdown"
		>
			<li>
				<button
					type="button"
					class="dropdown-item complete-signup-country__option"
					data-country-code=""
					data-country-name="<%= t('common:selectCountry') %>"
				>
					<span class="complete-signup-country__placeholder">
						<%= t('common:selectCountry') %>
					</span>
				</button>
			</li>
			<% ;(countryOptions || []).forEach((country) => { %>
				<li>
					<button
						type="button"
						class="dropdown-item complete-signup-country__option"
						data-country-code="<%= country.code %>"
						data-country-name="<%= country.name %>"
					>
						<span
							class="fi fi-<%= country.code.toLowerCase() %> complete-signup-country__flag"
							aria-hidden="true"
						></span>
						<span><%= country.name %></span>
					</button>
				</li>
			<% }) %>
		</ul>
	</div>
	<button
		type="submit"
		class="profile-icon-button profile-icon-button--success has-tooltip"
		data-bs-title="<%= t('common:saveCountry') %>"
		aria-label="<%= t('common:saveCountry') %>"
	>
		<i class="bi bi-check-lg" aria-hidden="true"></i>
	</button>
	<button
		type="button"
		class="profile-icon-button profile-icon-button--danger has-tooltip"
		data-country-cancel
		data-bs-title="<%= t('common:cancel') %>"
		aria-label="<%= t('common:cancel') %>"
	>
		<i class="bi bi-x-lg" aria-hidden="true"></i>
	</button>
</form>
