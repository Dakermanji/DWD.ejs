<!--! views/modals/auth/_complete_signup.ejs -->

<%
	const isLocal = modal === 'complete_signup_local';
	const action = isLocal ? 'complete-local-signup' : 'set-username';
%>

<div
	class="modal fade"
	id="completeSignUpModal"
	tabindex="-1"
	aria-labelledby="completeSignUpModalLabel"
	aria-hidden="true"
>
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">

			<div class="modal-header">
				<h5 class="modal-title" id="completeSignUpModalLabel">
					<%= t('auth:signup.complete_title') %>
				</h5>
				<button
					type="button"
					class="btn-close"
					data-bs-dismiss="modal"
					aria-label="Close"
				></button>
			</div>

			<form method="POST" action="/auth/<%= action %>">
				<%- include('../../partials/_csrf') %>
				<div class="modal-body">

					<!-- Username -->
					<div class="mb-3">
						<label for="username" class="form-label">
							<%= t('common:username') %>
						</label>
						<input
							id="username"
							dir="ltr"
							type="text"
							class="form-control"
							name="username"
							required
						/>
					</div>

					<!-- Avatar seed -->
					<div class="mb-3">
						<label for="avatarSeed" class="form-label">
							<%= t('common:avatarSeed') %>
						</label>
						<input
							id="avatarSeed"
							dir="ltr"
							type="text"
							class="form-control"
							name="avatarSeed"
							maxlength="64"
						/>
					</div>

					<!-- Country -->
					<div class="mb-3">
						<label for="countryCode" class="form-label">
							<%= t('common:country') %>
						</label>
						<select id="countryCode" class="form-select" name="countryCode">
							<option value=""><%= t('common:selectCountry') %></option>
							<% ;(countryOptions || []).forEach((country) => { %>
								<option value="<%= country.code %>"><%= country.name %></option>
							<% }) %>
						</select>
					</div>

					<% if (isLocal) { %>
						<%- include('./_setPassword', {token}) %>
					<% } %>

				</div>

				<div class="modal-footer">
					<button type="submit" class="btn btn-action w-100">
						<%= t('auth:signup.complete_button') %>
					</button>
				</div>
			</form>

		</div>
	</div>
</div>
