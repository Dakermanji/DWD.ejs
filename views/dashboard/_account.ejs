<!--! views/dashboard/_account.ejs -->
<section aria-labelledby="dashboard-account-title" class="py-4">
	<div class="d-flex align-items-center gap-3">
		<div class="position-relative flex-shrink-0">
			<div
				id="avatar"
				class="dashboard-avatar"
				style="background-color: <%= account.avatar.background %>;"
			>
				<img
					src="<%= account.avatar.src %>"
					alt=""
					class="avatar-img"
				/>
			</div>
			<button
				type="button"
				class="dashboard-avatar-edit has-tooltip"
				data-bs-toggle="modal"
				data-bs-target="#dashboardAvatarModal"
				data-bs-title="<%= t('common:editAvatar') %>"
				aria-label="<%= t('common:editAvatar') %>"
			>
				<i class="bi bi-pencil-fill" aria-hidden="true"></i>
			</button>

			<% if (account.countryCode) { %>
				<span
					class="avatar-country has-tooltip"
					data-bs-title="<%= account.countryName %>"
				>
					<span
						class="fi fi-<%= account.countryCode.toLowerCase() %> avatar-country__flag"
						role="img"
						aria-label="<%= account.countryName %>"
					></span>
				</span>
			<% } %>
		</div>

		<div class="min-w-0 dashboard-account-details">
			<div class="dashboard-username" data-dashboard-username>
				<div class="dashboard-username__display" data-username-display>
					<h2 id="dashboard-account-title" class="h4 mb-1">
						<%= account.username %>
					</h2>
					<button
						type="button"
						class="dashboard-icon-button has-tooltip"
						data-username-edit
						data-bs-title="<%= t('common:editName') %>"
						aria-label="<%= t('common:editName') %>"
					>
						<i class="bi bi-pencil-fill" aria-hidden="true"></i>
					</button>
				</div>

				<form
					class="dashboard-username__form d-none"
					method="POST"
					action="/dashboard/username"
					data-username-form
				>
					<%- include('../partials/_csrf') %>
					<input
						type="text"
						class="form-control dashboard-username__input"
						name="username"
						value="<%= account.username %>"
						required
						dir="ltr"
					/>
					<button
						type="submit"
						class="dashboard-icon-button dashboard-icon-button--success has-tooltip"
						data-bs-title="<%= t('common:saveName') %>"
						aria-label="<%= t('common:saveName') %>"
					>
						<i class="bi bi-check-lg" aria-hidden="true"></i>
					</button>
					<button
						type="button"
						class="dashboard-icon-button dashboard-icon-button--danger has-tooltip"
						data-username-cancel
						data-bs-title="<%= t('common:cancel') %>"
						aria-label="<%= t('common:cancel') %>"
					>
						<i class="bi bi-x-lg" aria-hidden="true"></i>
					</button>
				</form>
			</div>
			<p class="mb-0 text-body-muted"><%= account.email %></p>
		</div>
	</div>
</section>

<%- include('../modals/dashboard/_avatar_modal', { account, avatarStyleOptions }) %>
