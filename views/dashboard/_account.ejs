<!--! views/dashboard/_account.ejs -->
<section aria-labelledby="dashboard-account-title" class="py-4">
	<div class="d-flex align-items-center gap-3">
		<div class="position-relative flex-shrink-0">
			<div
				id="avatar"
				class="rounded-circle border overflow-hidden"
				style="width: 88px; height: 88px; background-color: <%= account.avatarBackground %>;"
			>
				<img
					src="<%= account.avatar %>"
					alt=""
					class="avatar-img"
					width="88"
					height="88"
				/>
			</div>

			<% if (account.countryCode) { %>
				<span
					class="position-absolute bottom-0 end-0 rounded-circle border bg-body p-1 has-tooltip"
					data-bs-title="<%= account.countryName %>"
				>
					<span
						class="fi fi-<%= account.countryCode.toLowerCase() %>"
						role="img"
						aria-label="<%= account.countryName %>"
					></span>
				</span>
			<% } %>
		</div>

		<div class="min-w-0">
			<h2 id="dashboard-account-title" class="h4 mb-1">
				<%= account.username %>
			</h2>
			<p class="mb-0 text-body-secondary"><%= account.email %></p>
		</div>
	</div>
</section>
