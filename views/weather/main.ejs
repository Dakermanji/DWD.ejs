<!--! views/weather/main.ejs -->
<%
	const hasForecast = Array.isArray(forecastDays) && forecastDays.length > 0;
	const activeDay = hasForecast ? forecastDays[0] : null;
	const pageBackgroundImage = activeDay?.backgroundImage || '';
	const pageBackgroundCredit = activeDay?.backgroundCredit || null;
	const formatCssImage = (imageUrl) => `url('${String(imageUrl).replace(/\\/g, '\\\\').replace(/'/g, "\\'")}')`;
	const pageStyle = pageBackgroundImage ? ` style="--weather-bg-image: ${formatCssImage(pageBackgroundImage)}"` : '';
	const localizedComma = t('common:comma');
	const locationLabel = [location.city, location.state, location.country]
		.filter(Boolean)
		.join(localizedComma);
	const hasLocation = Boolean(locationLabel);
	const isArabic = currentLang === 'ar';
	const formatTemperature = (value) => isArabic ? `°${value}` : `${value}°`;
	const formatPercent = (value) => isArabic ? `%${value}` : `${value}%`;
	const formatSpeed = (value, unit) => `${value} ${t(`weather:measurementUnits.${unit}`)}`;
	const formatDistance = (value, unit) => `${value} ${t(`weather:measurementUnits.${unit}`)}`;
	const formatPressure = (value) => isArabic ? `hPa ${value}` : `${value} hPa`;
	const formatCondition = (condition) => t(`weather:conditions.${condition}`);
	const formatDirectionGusts = (direction, gust, unit) => {
		const directionLabel = t(`weather:directions.${direction}`);
		const gustLabel = formatSpeed(gust, unit);

		return isArabic
			? `${gustLabel} - ${directionLabel}`
			: `${directionLabel}${localizedComma}${gustLabel}`;
	};
%>

<section class="weather-page" aria-labelledby="weather-title"<%- pageStyle %>>
	<div class="weather-shell">
		<div class="weather-hero">
			<div>
				<p class="weather-kicker"><%= t('weather:kicker') %></p>
				<h1 id="weather-title" class="weather-location">
					<% if (hasLocation && location.countryCode) { %>
						<span
							class="fi fi-<%= location.countryCode.toLowerCase() %> weather-location__flag"
							role="img"
							aria-label="<%= location.country %>"
						></span>
					<% } %>
					<% if (hasLocation) { %>
						<span><%= locationLabel %></span>
					<% } %>
				</h1>
			</div>

			<div class="weather-mascot" aria-hidden="true">
				<img
					src="<%= activeDay?.mascotImage || '/images/weather/maple-coder-weather-default.png' %>"
					alt=""
				/>
			</div>
		</div>

		<form class="weather-search" action="/weather" method="get">
			<label class="visually-hidden" for="weather-city"><%= t('weather:search.city') %></label>
			<input type="hidden" name="latitude" data-weather-latitude />
			<input type="hidden" name="longitude" data-weather-longitude />
			<input type="hidden" name="viewportWidth" data-weather-viewport-width />
			<input type="hidden" name="viewportHeight" data-weather-viewport-height />
			<div class="input-group">
				<span class="input-group-text"><i class="bi bi-search"></i></span>
				<input
					id="weather-city"
					class="form-control"
					type="search"
					placeholder="<%= t('weather:search.placeholder') %>"
					autocomplete="address-level2"
					aria-autocomplete="list"
					aria-controls="weather-city-results"
					aria-expanded="false"
					data-weather-city-input
				/>
				<button
					class="btn btn-action-outline weather-current-location has-tooltip"
					type="button"
					data-weather-current-location
					data-bs-title="<%= t('weather:search.currentLocation') %>"
					aria-label="<%= t('weather:search.currentLocation') %>"
				>
					<i class="bi bi-crosshair" aria-hidden="true"></i>
				</button>
				<div
					id="weather-city-results"
					class="weather-city-results"
					role="listbox"
					aria-label="<%= t('weather:search.results') %>"
					data-weather-city-results
					data-empty-label="<%= t('weather:search.noResults') %>"
					hidden
				></div>
			</div>

			<div class="weather-units" role="group" aria-label="<%= t('weather:units.label') %>">
				<input
					class="btn-check"
					type="radio"
					name="unit"
					id="weather-unit-metric"
					value="metric"
					<%= unit === 'metric' ? 'checked' : '' %>
				/>
				<label class="btn btn-action-outline" for="weather-unit-metric"><%= t('weather:units.metric') %></label>

				<input
					class="btn-check"
					type="radio"
					name="unit"
					id="weather-unit-imperial"
					value="imperial"
					<%= unit === 'imperial' ? 'checked' : '' %>
				/>
				<label class="btn btn-action-outline" for="weather-unit-imperial"><%= t('weather:units.imperial') %></label>
			</div>
		</form>

		<% if (hasForecast) { %>
			<ul class="nav nav-tabs weather-tabs" id="weatherForecastTabs" role="tablist">
				<% forecastDays.forEach((day, index) => { %>
					<%
						const dayLabel = day.labelKey === 'day'
							? t('weather:days.day', { number: day.dayNumber })
							: t(`weather:days.${day.labelKey}`);
					%>
					<li class="nav-item" role="presentation">
						<button
							class="nav-link <%= index === 0 ? 'active' : '' %>"
							id="<%= day.id %>-tab"
							data-bs-toggle="tab"
							data-bs-target="#<%= day.id %>-panel"
							type="button"
							role="tab"
							aria-controls="<%= day.id %>-panel"
							aria-selected="<%= index === 0 ? 'true' : 'false' %>"
						>
							<i class="bi <%= day.icon %>"></i>
							<span><%= dayLabel %></span>
						</button>
					</li>
				<% }) %>
			</ul>

			<div class="tab-content weather-panels" id="weatherForecastTabContent">
				<% forecastDays.forEach((day, index) => { %>
					<%
						const dayLabel = day.labelKey === 'day'
							? t('weather:days.day', { number: day.dayNumber })
							: t(`weather:days.${day.labelKey}`);
						const panelStyle = day.backgroundImage
							? ` style="--weather-panel-bg-image: ${formatCssImage(day.backgroundImage)}"`
							: '';
						const precipitationLabel = day.precipitation
							? `${day.precipitation.volume} mm ${day.precipitation.type}`
							: null;
						const weatherMetrics = [
							{ icon: 'bi-thermometer-half', label: t('weather:metrics.temperature'), value: formatTemperature(day.temp) },
							{ icon: 'bi-thermometer-sun', label: t('weather:metrics.feelsLike'), value: formatTemperature(day.feelsLike) },
							{ icon: 'bi-thermometer-high', label: t('weather:metrics.minMax'), value: `${formatTemperature(day.low)} / ${formatTemperature(day.high)}` },
							{ icon: 'bi-droplet-fill', label: t('weather:metrics.humidity'), value: formatPercent(day.humidity) },
							{ icon: 'bi-speedometer2', label: t('weather:metrics.pressure'), value: formatPressure(day.pressure) },
							{ icon: 'bi-wind', label: t('weather:metrics.wind'), value: formatSpeed(day.wind, day.windUnit) },
							{ icon: 'bi-compass', label: t('weather:metrics.directionGusts'), value: formatDirectionGusts(day.windDirection, day.windGust, day.windUnit) },
							{ icon: 'bi-clouds-fill', label: t('weather:metrics.cloudiness'), value: formatPercent(day.cloudiness) },
							{ icon: 'bi-eye-fill', label: t('weather:metrics.visibility'), value: formatDistance(day.visibility, day.visibilityUnit) },
							{ icon: 'bi-sunrise-fill', label: t('weather:metrics.sunrise'), value: day.sunrise },
							{ icon: 'bi-sunset-fill', label: t('weather:metrics.sunset'), value: day.sunset },
							{ icon: 'bi-cloud-fill', label: t('weather:metrics.condition'), value: formatCondition(day.condition) },
						];

						if (precipitationLabel) {
							weatherMetrics.push({
								icon: day.precipitation.type === 'snow' ? 'bi-cloud-snow-fill' : 'bi-cloud-rain-heavy-fill',
								label: t('weather:metrics.precipitation'),
								value: precipitationLabel,
							});
						}
					%>
					<article
						class="tab-pane fade weather-panel <%= index === 0 ? 'show active' : '' %>"
						id="<%= day.id %>-panel"
						role="tabpanel"
						aria-labelledby="<%= day.id %>-tab"
						tabindex="0"
						<%- panelStyle %>
					>
						<div class="weather-panel__main">
							<i
								class="has-tooltip bi <%= day.icon %>"
								data-bs-title="<%= formatCondition(day.condition) %>: <%= day.description %>"
								data-bs-toggle="tooltip"
							></i>
							<div>
								<p class="weather-panel__day"><%= dayLabel %></p>
								<p class="weather-panel__temp"><%= formatTemperature(day.temp) %></p>
								<p class="weather-panel__summary"><%= day.summary %></p>
							</div>
							<div
								class="weather-clock"
								data-weather-clock
								data-timezone-offset="<%= day.timezoneOffset %>"
								aria-label="<%= t('weather:clock.localTime') %>"
							>
								<i class="bi bi-clock" aria-hidden="true"></i>
								<span class="weather-clock__time" data-weather-clock-time>--:--</span>
								<span class="weather-clock__date" data-weather-clock-date>--/--/----</span>
								<span class="weather-clock__offset" data-weather-clock-offset>UTC</span>
							</div>
						</div>

						<div class="weather-metrics">
							<% weatherMetrics.forEach((metric) => { %>
								<div class="weather-metric">
									<i class="bi <%= metric.icon %>" aria-hidden="true"></i>
									<span><%= metric.label %></span>
									<strong><%= metric.value %></strong>
								</div>
							<% }) %>
						</div>
					</article>
				<% }) %>
			</div>
		<% } else { %>
			<div class="weather-empty">
				<i class="bi bi-cloud"></i>
				<p><%= t('weather:empty') %></p>
			</div>
		<% } %>
	</div>

	<% if (pageBackgroundCredit) { %>
		<p class="weather-attribution">
			<%= t('weather:background.photoBy') %>
			<a href="<%= pageBackgroundCredit.photographerUrl %>" target="_blank" rel="noopener noreferrer">
				<%= pageBackgroundCredit.photographerName %>
			</a>
			<%= t('weather:background.on') %>
			<a href="<%= pageBackgroundCredit.unsplashUrl %>" target="_blank" rel="noopener noreferrer">
				Unsplash
			</a>
		</p>
	<% } %>
</section>
