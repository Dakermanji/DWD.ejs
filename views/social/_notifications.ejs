<!--! views/social/_notifications.ejs -->
<div
	class="accordion-item"
>
	<h3 class="accordion-header">
		<button
			class="accordion-button collapsed"
			type="button"
			data-bs-toggle="collapse"
			data-bs-target="#socialNotifications"
			aria-expanded="false"
			aria-controls="socialNotifications"
		>
			<%= t('social:notifications.title') %>
		</button>
	</h3>
	<div
		id="socialNotifications"
		class="accordion-collapse collapse"
		data-bs-parent="#socialAccordion"
	>
		<div
			class="accordion-body"
			id="socialNotificationsBody"
			data-url="/social/notifications"
			data-action-url="/social/actions"
			data-loading-label="<%= t('social:notifications.loading') %>"
			data-empty-label="<%= t('social:notifications.empty') %>"
			data-error-label="<%= t('social:notifications.error') %>"
			data-follow-request-label="<%= t('social:notifications.follow_request') %>"
			data-follow-started-label="<%= t('social:notifications.follow_started') %>"
			data-follow-request-accepted-label="<%= t('social:notifications.follow_request_accepted') %>"
			data-follow-request-accepted-followed-back-label="<%= t('social:notifications.follow_request_accepted_followed_back') %>"
			data-someone-label="<%= t('social:notifications.someone') %>"
			data-accept-label="<%= t('social:notifications.actions.accept') %>"
			data-follow-back-label="<%= t('social:notifications.actions.follow_back') %>"
			data-decline-label="<%= t('social:notifications.actions.decline') %>"
			data-block-label="<%= t('social:notifications.actions.block') %>"
			data-ignore-label="<%= t('social:notifications.actions.ignore') %>"
			data-action-error-label="<%= t('social:notifications.action_error') %>"
		></div>
	</div>
</div>
